{
  "name": "clinical-documentation-transformer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:test": "next dev --port 3001",
    "build": "next build",
    "start": "next start",
    "lint": "npx eslint .",
    "test": "vitest run",
    "atlas:gate": "node scripts/atlas-regression-gate.mjs",
    "atlas:live-conversation": "npx tsx scripts/live-assistant-conversation-qa.mjs",
    "atlas:live-conversation:route": "npx vitest run --silent=true --maxWorkers=1 tests/live-assistant-conversation-route.test.ts",
    "live:assistant:qa": "npx tsx scripts/live-assistant-webpage-qa.mjs",
    "live:assistant:route-qa": "npx tsx scripts/run-live-assistant-route-qa.mjs",
    "eval:vera": "npx tsx lib/veranote/evals/eval-runner.ts",
    "generate": "node lib/note/generate-notes.js",
    "import:psych-meds": "node scripts/import-psych-med-seed.mjs",
    "import:psych-terms": "node scripts/import-psych-terminology-seed.mjs",
    "import:psych-dx": "node scripts/import-psych-diagnosis-seed.mjs"
  },
  "dependencies": {
    "@auth/pg-adapter": "^1.11.2",
    "@supabase/supabase-js": "^2.104.0",
    "@veranote/nodemailer": "npm:nodemailer@^8.0.7",
    "next": "^16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "openai": "^6.32.0",
    "pg": "^8.20.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "supertest": "^7.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.17",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "eslint": "^10.2.0",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "postcss": "^8.5.13",
    "tailwindcss": "3.4.7",
    "typescript": "5.5.4",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "postcss": "$postcss",
    "anymatch": {
      "picomatch": "2.3.2"
    },
    "micromatch": {
      "picomatch": "2.3.2"
    },
    "readdirp": {
      "picomatch": "2.3.2"
    }
  }
}
